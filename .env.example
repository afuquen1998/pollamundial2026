# ─── OpenAI (cerebro: Responses API + web_search) ─────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5

# ─── Evolution API (WhatsApp) ─────────────────────────────────
EVOLUTION_URL=https://tu-evolution.tu-dominio   # sin slash final
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=tu_instancia
MI_NUMERO=57XXXXXXXXXX                          # con indicativo, sin +

# ─── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...                     # service_role key (Settings → API)

# Connection string directa a Postgres (Settings → Database → Connection string, URI).
# Solo se usa para crear la tabla (DDL). Si no la das, corre el SQL a mano en el dashboard.
SUPABASE_DB_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── Opcionales ───────────────────────────────────────────────
# Por defecto la ventana es "hasta el fin del día de hoy en Bogotá" (solo partidos de HOY).
# Si se setea, usa una ventana fija de N horas desde ahora (modo viejo, solo para pruebas).
#WINDOW_HOURS=36
# Formato del body de Evolution: v2 = {number,text} | legacy = {number,textMessage:{text}}
EVOLUTION_BODY_STYLE=v2

# ─── Polla Futbolera Alumni (login con código, Playwright headless) ──
PF_CODIGO=

# ─── Predicción Ganadora (login email+clave, HTTP puro) ──────────────
PG_EMAIL=
PG_CLAVE=
#PG_CLIENTE_URL=https://www.prediccionganadora.com/clientes/areandina

# ─── Publicación de marcadores ────────────────────────────────────────
PUBLISH_DEFAULT_TARGET=ambas   # ambas|futbolera|prediccion
#PUBLISH_DRY_RUN=true           # true = no escribe, solo simula

# ─── Servidor (server.js: cron + webhook de WhatsApp) ─────────────────
PORT=3000
WEBHOOK_TOKEN=                 # string aleatorio largo; ruta POST /webhook/<token>

# ─── Trivia automática (Iniciativa A) ─────────────────────────────────
# DESACTIVADA por defecto. Activar SOLO tras verificar el primer envío supervisado.
#TRIVIA_ENABLED=true
#TRIVIA_SCHEDULE=*/15 6-23 * * *       # cuándo sondear (Bogotá); por defecto cada 15 min, 6am-11pm
#TRIVIA_HORA_ALEATORIA=true            # responder a una hora aleatoria de la mañana (rompe patrón). Velocidad de respuesta intacta.
#TRIVIA_HORA_INI=06:00                 # inicio de la ventana de respuesta aleatoria (Bogotá)
#TRIVIA_HORA_FIN=08:50                 # fin de la ventana (antes de las 9am). Si la pregunta aparece después, igual la responde ASAP.
#TRIVIA_TIMEOUT_MS=12000               # límite del solver (de los 20s totales)
#TRIVIA_EFFORT=low                     # esfuerzo de razonamiento del solver
#TRIVIA_MAX_TOKENS=3000
