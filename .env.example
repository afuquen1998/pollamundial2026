# ─── OpenAI (cerebro: Responses API + web_search) ─────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5

# ─── Evolution API (WhatsApp) ─────────────────────────────────
EVOLUTION_URL=https://tu-evolution.tu-dominio   # sin slash final
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=tu_instancia
MI_NUMERO=57XXXXXXXXXX                          # con indicativo, sin +

# ─── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...                     # service_role key (Settings → API)

# Connection string directa a Postgres (Settings → Database → Connection string, URI).
# Solo se usa para crear la tabla (DDL). Si no la das, corre el SQL a mano en el dashboard.
SUPABASE_DB_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── Opcionales ───────────────────────────────────────────────
# Por defecto la ventana es "hasta el fin del día de hoy en Bogotá" (solo partidos de HOY).
# Si se setea, usa una ventana fija de N horas desde ahora (modo viejo, solo para pruebas).
#WINDOW_HOURS=36
# Formato del body de Evolution: v2 = {number,text} | legacy = {number,textMessage:{text}}
EVOLUTION_BODY_STYLE=v2
